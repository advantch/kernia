    "clsx": "^2.1.1",
    "framer-motion": "^12.23.12",
    "fumadocs-core": "16.9.2",
    "fumadocs-mdx": "15.0.9",
    "fumadocs-typescript": "^5.2.1",
    "fumadocs-ui": "16.9.2",
    "geist": "^1.7.0",
    "lucide-react": "^1.7.0",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.0.0",
    "sonner": "^2.0.7",
