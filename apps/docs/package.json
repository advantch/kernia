{
  "name": "kernia-docs",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "fumadocs-mdx",
    "dev": "next dev --port 3000",
    "build": "next build",
    "start": "next start",
    "typecheck": "fumadocs-mdx && tsc --noEmit",
