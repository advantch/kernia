{
  "framework": "vite",
  "buildCommand": "npm run build",
  "installCommand": "npm install --no-package-lock",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "regions": ["iad1"]
}
